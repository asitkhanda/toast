<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Toast.Views.PopoverPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="HeaderTitle" Text="Toast" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="HeaderSubtitle" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
                </StackPanel>
                <Button Grid.Column="1" Content="Settings" Click="Settings_Click" />
            </Grid>
        </StackPanel>

        <ListView x:Name="StatusList" Grid.Row="1" Margin="0,12,0,12" SelectionMode="None" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button Content="Refresh" Click="Refresh_Click" />
            <Button Content="Feedback" Click="Feedback_Click" />
            <Button x:Name="UpdateButton" Content="Check for updates" Click="Update_Click" Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</Page>
