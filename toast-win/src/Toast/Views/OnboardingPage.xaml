<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Toast.Views.OnboardingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="20">
        <StackPanel Spacing="16" MaxWidth="360">
            <TextBlock Text="Toast" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock x:Name="StepTitle" Text="Connect your Vercel token" TextWrapping="WrapWholeWords"
                       Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock
                x:Name="TokenHelpText"
                Text="Use a read-only, team-scoped personal access token."
                TextWrapping="WrapWholeWords"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <PasswordBox x:Name="TokenBox" PlaceholderText="Vercel token" PasswordRevealMode="Peek" />
            <HyperlinkButton
                x:Name="TokenHelpLink"
                Content="How to create a token"
                NavigateUri="https://vercel.com/account/tokens" />

            <TextBlock x:Name="ErrorText" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="WrapWholeWords" Visibility="Collapsed" />
            <TextBlock x:Name="ScopeWarning" Foreground="{ThemeResource SystemFillColorCautionBrush}" TextWrapping="WrapWholeWords" Visibility="Collapsed" />

            <ListView x:Name="ProjectList" SelectionMode="Multiple" MaxHeight="220" Visibility="Collapsed" />

            <StackPanel x:Name="BackgroundPanel" Spacing="8" Visibility="Collapsed">
                <ToggleSwitch x:Name="LaunchAtLoginToggle" Header="Launch at login" IsOn="True" />
                <ToggleSwitch x:Name="RunInBackgroundToggle" Header="Keep running in tray" IsOn="True" />
                <ToggleSwitch x:Name="RelaunchOnCrashToggle" Header="Relaunch after crash" IsOn="True" />
            </StackPanel>

            <Button x:Name="PrimaryButton" Content="Continue" Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch" Click="PrimaryButton_Click" />
        </StackPanel>
    </ScrollViewer>
</Page>
